{
	"name": "rbxts-harness",
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"node_modules": {
				"$className": "Folder",
				"@rbxts": {
					"$path": "node_modules/@rbxts"
				},
				"@rbxts-js": {
					"$path": "../../node_modules/@rbxts-js"
				},
				"@vela-rbxts": {
					"$path": "node_modules/@vela-rbxts"
				}
			},
			"TS": {
				"$path": "include"
			}
		},
		"StarterPlayer": {
			"$className": "StarterPlayer",
			"StarterPlayerScripts": {
				"$className": "StarterPlayerScripts",
				"Client": {
					"$path": "out/client"
				}
			}
		}
	}
}
