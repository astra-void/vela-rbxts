{
	"name": "rbxts-harness",
	"version": "0.1.0-next.0",
	"private": true,
	"scripts": {
		"prebuild": "pnpm --filter vela-rbxts build",
		"build": "rbxtsc -p tsconfig.json",
		"predev": "pnpm --filter vela-rbxts build",
		"dev": "rbxtsc -w -p tsconfig.json",
		"test": "pnpm run build && node scripts/verify-rbxtsc-output.cjs",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint": "biome check .",
		"lint:fix": "biome check . --fix --unsafe",
		"clean": "node -e \"const fs=require('node:fs');fs.rmSync('out',{recursive:true,force:true});\""
	},
	"dependencies": {
		"vela-rbxts": "workspace:*",
		"@rbxts/react": "^17.3.7-ts.1",
		"@rbxts/react-roblox": "^17.3.7-ts.1",
		"@rbxts/services": "^1.6.0"
	},
	"devDependencies": {
		"@rbxts/compiler-types": "^3.0.0-types.0",
		"@rbxts/types": "^1.0.916",
		"roblox-ts": "^3.0.0",
		"typescript": "5.9.3"
	}
}
