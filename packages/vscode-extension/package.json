{
	"name": "vela-rbxts-lsp",
	"version": "0.1.0-next.0",
	"type": "commonjs",
	"displayName": "Vela LSP",
	"publisher": "astra-void",
	"description": "VS Code extension that launches the standalone Vela RBXTS Rust LSP.",
	"main": "./dist/extension.js",
	"engines": {
		"vscode": "^1.90.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/astra-void/vela-rbxts.git"
	},
	"license": "MIT",
	"activationEvents": [
		"onLanguage:typescript",
		"onLanguage:typescriptreact"
	],
	"contributes": {
		"configuration": {
			"title": "vela-rbxts",
			"properties": {
				"velaRbxts.lsp.serverPath": {
					"type": "string",
					"default": "",
					"description": "Optional path to the standalone vela-rbxts LSP executable. When empty, the extension uses the published @vela-rbxts/lsp wrapper package when its matching platform binary dependency is installed."
				},
				"velaRbxts.lsp.trace.server": {
					"type": "string",
					"default": "off",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"description": "Trace level forwarded to the vela-rbxts language client."
				},
				"velaRbxts.lsp.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable the standalone vela-rbxts Rust LSP integration for TypeScript and TSX files."
				}
			}
		}
	},
	"scripts": {
		"build": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=es2022 --packages=external --outfile=dist/extension.js --sourcemap",
		"dev": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=es2022 --packages=external --outfile=dist/extension.js --sourcemap --watch",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome check src",
		"clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});\"",
		"vscode:prepublish": "pnpm run build",
		"package:vsix": "pnpm run clean && pnpm run build && node ./scripts/package-vsix.cjs",
		"publish:vsix": "node ./scripts/publish-vsix.cjs"
	},
	"dependencies": {
		"@vela-rbxts/lsp": "workspace:*",
		"vscode-languageclient": "^9.0.1"
	},
	"devDependencies": {
		"esbuild": "^0.27.7",
		"@vscode/vsce": "^3.6.2",
		"@types/node": "^24.10.1",
		"@types/vscode": "^1.90.0",
		"typescript": "5.9.3"
	}
}
