{
  "name": "@vela-rbxts/compiler",
  "version": "0.1.1-next.0",
  "private": false,
  "type": "commonjs",
  "description": "Native compiler implementation for @vela-rbxts/compiler.",
  "main": "./entry.cjs",
  "types": "./entry.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/astra-void/vela-rbxts.git"
  },
  "files": [
    "entry.cjs",
    "entry.d.ts",
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "exports": {
    ".": {
      "types": "./entry.d.ts",
      "import": "./entry.cjs",
      "require": "./entry.cjs",
      "default": "./entry.cjs"
    },
    "./native": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "napi": {
    "binaryName": "compiler",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "pnpm run build:native",
    "build:native": "napi build --platform",
    "build:native:target": "node ./scripts/build-target-artifact.mjs",
    "dev": "pnpm run build:native",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix --unsafe",
    "create-npm-dirs": "node ./scripts/create-npm-dirs.mjs",
    "prepack": "pnpm run clean && pnpm run build",
    "prepublish:napi": "pnpm run stage:napi",
    "publish:napi": "node ./scripts/publish-napi.mjs",
    "publish:napi:dry-run": "node ./scripts/publish-napi.mjs --dry-run",
    "test": "pnpm run build:native && vitest run test/*.test.ts",
    "stage:napi": "node ./scripts/publish-napi.mjs --prepare-only",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('node:fs');for (const file of ['dist','index.js','index.d.ts','.npm','npm']) fs.rmSync(file,{recursive:true,force:true});for (const entry of fs.readdirSync('.')) if (entry.endsWith('.node')) fs.rmSync(entry,{force:true});\""
  },
  "devDependencies": {
    "@vela-rbxts/config": "workspace:*",
    "@napi-rs/cli": "^3.6.2"
  }
}
