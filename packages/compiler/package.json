{
  "name": "@rbxts-tailwind/compiler",
  "version": "0.1.0",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "napi": {
    "binaryName": "compiler",
		"targets": [
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-unknown-linux-gnu",
			"x86_64-pc-windows-msvc",
			"x86_64-unknown-linux-musl",
			"aarch64-unknown-linux-gnu",
			"aarch64-unknown-linux-musl",
			"aarch64-pc-windows-msvc"
		]
  },
  "scripts": {
    "build": "pnpm run build:native",
    "build:native": "napi build --platform",
    "dev": "pnpm run build:native",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix --unsafe",
    "test": "pnpm run build:native && vitest run test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});\""
  },
  "devDependencies": {
    "@rbxts-tailwind/config": "workspace:*",
    "@napi-rs/cli": "^3.6.2"
  }
}
