{
  "name": "@vela-rbxts/compiler",
  "version": "0.1.0",
  "type": "commonjs",
  "main": "./entry.cjs",
  "types": "./entry.d.ts",
  "exports": {
    ".": {
      "types": "./entry.d.ts",
      "import": "./entry.cjs",
      "require": "./entry.cjs",
      "default": "./entry.cjs"
    },
    "./native": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "napi": {
    "binaryName": "compiler",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "pnpm run build:native",
    "build:native": "napi build --platform",
    "dev": "pnpm run build:native",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix --unsafe",
    "test": "pnpm run build:native && vitest run test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});\""
  },
  "devDependencies": {
    "@vela-rbxts/config": "workspace:*",
    "@napi-rs/cli": "^3.6.2"
  }
}
