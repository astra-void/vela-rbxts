{
  "name": "vela-rbxts",
  "version": "0.1.0-next.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./transformer": {
      "types": "./dist/transformer.d.cts",
      "import": "./dist/transformer.cjs",
      "require": "./dist/transformer.cjs",
      "default": "./dist/transformer.cjs"
    }
  },
  "files": [
    "dist",
    "transformer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/astra-void/vela-rbxts"
  },
  "scripts": {
    "build": "pnpm run build:types",
    "build:types": "tsc -b tsconfig.json",
    "dev": "tsc -b tsconfig.json --watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix --unsafe",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});\""
  },
  "dependencies": {
    "@rbxts/react": "^17.3.7-ts.1",
    "@rbxts/services": "^1.6.0",
    "@vela-rbxts/config": "workspace:*",
    "@vela-rbxts/rbxtsc-host": "workspace:*",
    "@vela-rbxts/types": "workspace:*"
  },
  "devDependencies": {
    "@rbxts/compiler-types": "^3.0.0-types.0",
    "@rbxts/types": "^1.0.916",
    "roblox-ts": "^3.0.0"
  }
}
