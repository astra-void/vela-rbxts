{
  "name": "vela-rbxts",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./transformer": {
      "types": "./dist/transformer.d.cts",
      "import": "./dist/transformer.cjs",
      "require": "./dist/transformer.cjs",
      "default": "./dist/transformer.cjs"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "dev": "tsc -b tsconfig.json --watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix --unsafe",
    "test": "vitest run test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});\""
  },
  "dependencies": {
    "@vela-rbxts/config": "workspace:*",
    "@vela-rbxts/rbxtsc-host": "workspace:*",
    "@vela-rbxts/types": "workspace:*"
  }
}
