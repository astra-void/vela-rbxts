{
  "name": "@vela-rbxts/config",
  "version": "0.1.0-next.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/astra-void/vela-rbxts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "generate:defaults": "node scripts/generate-defaults.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix --unsafe",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});\""
  },
  "dependencies": {
    "@vela-rbxts/types": "workspace:*"
  }
}
